{
    // Rolling Bonxai dev container — ROS 2 Jazzy (Ubuntu 24.04 Noble)
    //
    // Use this when you want to develop on Jazzy. The SITL container
    // (roscon-25-workshop) runs Humble, but Fast-DDS is wire-compatible
    // across distros on the same ROS_DOMAIN_ID, so all /fmu/* and
    // /depth_camera/* topics are visible from both distros.
    //
    // Named volumes use a _jazzy suffix to avoid colliding with the
    // Humble devcontainer if both are ever open simultaneously.
    //
    // To open: CTRL+SHIFT+P → "Dev Containers: Reopen in Container"
    //           → select "rolling_bonxai_jazzy"
    "name": "rolling_bonxai_jazzy",

    "build": {
        "dockerfile": "../.docker/Dockerfile.rolling_bonxai_jazzy",
        "context": "..",
        "target": "deps"
    },

    "workspaceMount": "source=${localWorkspaceFolder},target=/ros2_ws/src/Rolling-Bonxai,type=bind,consistency=cached",
    "workspaceFolder": "/ros2_ws",

    "mounts": [
        { "source": "rolling_bonxai_build_jazzy",   "target": "/ros2_ws/build",   "type": "volume" },
        { "source": "rolling_bonxai_install_jazzy",  "target": "/ros2_ws/install", "type": "volume" },
        { "source": "rolling_bonxai_log_jazzy",      "target": "/ros2_ws/log",     "type": "volume" },
        { "source": "/tmp/.X11-unix", "target": "/tmp/.X11-unix", "type": "bind" }
    ],

    "remoteEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "ROS_DOMAIN_ID": "0"
    },

    "runArgs": [
        "--network=host",
        "--cap-add=SYS_PTRACE",
        "--security-opt", "seccomp=unconfined",
        "--device", "/dev/dri:/dev/dri"
    ],

    // on_create and post_start scripts are shared between both variants.
    // They detect the active ROS distro at runtime via $ROS_DISTRO.
    "onCreateCommand": "bash /ros2_ws/src/Rolling-Bonxai/.docker/devcontainer_on_create.sh",
    "postStartCommand": "bash /ros2_ws/src/Rolling-Bonxai/.docker/devcontainer_post_start.sh",

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "C_Cpp.default.compileCommands": "/ros2_ws/build/compile_commands.json",
                "cmake.buildDirectory": "/ros2_ws/build"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-iot.vscode-ros",
                "ms-python.python",
                "twxs.cmake",
                "ms-vscode.cmake-tools"
            ]
        }
    },

    "forwardPorts": [8765],
    "portsAttributes": {
        "8765": { "label": "Foxglove Bridge" }
    }
}
